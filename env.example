# Database
DATABASE_URL="postgresql://user:password@localhost:5432/practice"

# Auth.js
AUTH_SECRET="your-auth-secret-here"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Vercel AI Gateway（与 AI SDK 配合，见 https://vercel.com/docs/ai-gateway）
AI_GATEWAY_API_KEY="your-ai-gateway-api-key"
# 模型 ID，格式 provider/model，见 Gateway 文档 Models 列表
AI_GATEWAY_MODEL="anthropic/claude-sonnet-4-20250514"
